

echo "[husky] pre-push: running unit tests only (Feature/Integration tests run in CI)"

# Run only Unit tests (fast, no DB dependency).
# Feature tests are environment-sensitive and run in CI instead.
if [ -f composer.json ]; then
  echo "Running Pest unit tests..."
  vendor/bin/pest tests/Unit --compact || {
    echo "Unit tests failed - aborting push"
    exit 1
  }
else
  echo "composer.json not found; skipping Pest"
fi

echo "[husky] pre-push: unit tests passed"
