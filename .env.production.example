# =============================================================================
# STRATOS — Variables de Entorno para PRODUCCIÓN
# =============================================================================
# INSTRUCCIONES:
#   1. Copia este archivo como .env en el servidor de producción
#   2. Rellena TODOS los valores marcados con <CAMBIAR>
#   3. Nunca subas el .env real a git
#   4. Genera APP_KEY con: php artisan key:generate --show
# =============================================================================

# -----------------------------------------------------------------------------
# APLICACIÓN
# -----------------------------------------------------------------------------
APP_NAME="Stratos"
APP_ENV=production
APP_KEY=<CAMBIAR: php artisan key:generate --show>
APP_DEBUG=false
APP_URL=https://<CAMBIAR: tu-dominio.com>
APP_ASSET_URL=https://<CAMBIAR: tu-dominio.com>
APP_TIMEZONE=America/Santiago
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_CL
APP_MAINTENANCE_DRIVER=file

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=stratos_prod
DB_USERNAME=stratos_user
DB_PASSWORD=<CAMBIAR: contraseña fuerte >20 chars>

# -----------------------------------------------------------------------------
# REDIS (Caché, Colas y Sesiones)
# -----------------------------------------------------------------------------
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=<CAMBIAR: misma que requirepass en redis.conf>
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# COLAS Y CACHÉ
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_PREFIX=stratos_prod_cache
BROADCAST_CONNECTION=log

# -----------------------------------------------------------------------------
# SESIONES
# -----------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.<CAMBIAR: tu-dominio.com>
SESSION_SECURE_COOKIE=true

# -----------------------------------------------------------------------------
# FILESYSTEM
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
# SANCTUM (autenticación SPA)
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=<CAMBIAR: tu-dominio.com>,<CAMBIAR: staging.tu-dominio.com>

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
# Retención de logs (días)
LOG_DAILY_DAYS=30

# -----------------------------------------------------------------------------
# CORREO
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=<CAMBIAR: smtp.sendgrid.net o similar>
MAIL_PORT=587
MAIL_USERNAME=<CAMBIAR>
MAIL_PASSWORD=<CAMBIAR>
MAIL_FROM_ADDRESS=no-reply@<CAMBIAR: tu-dominio.com>
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# NOTIFICACIONES (Slack + Telegram)
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<CAMBIAR>
TELEGRAM_BOT_TOKEN=<CAMBIAR: bot de producción>
TELEGRAM_CHAT_ID=<CAMBIAR: grupo de alertas prod>

# -----------------------------------------------------------------------------
# MONITOREO DE ERRORES (Sentry)
# -----------------------------------------------------------------------------
SENTRY_LARAVEL_DSN=https://<CAMBIAR>@sentry.io/<CAMBIAR>
SENTRY_SEND_DEFAULT_PII=false
SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# IA / GENERACIÓN (si está habilitada en prod)
# -----------------------------------------------------------------------------
ABACUS_API_KEY=<CAMBIAR o dejar vacío si no se usa en prod>
ABACUS_BASE_URL=https://api.abacus.ai
ABACUS_MODEL=<CAMBIAR>
ABACUS_TIMEOUT=30
DEEPSEEK_API_KEY=<CAMBIAR o dejar vacío>

IMPORT_GENERATION=false
FEATURE_GENERATE_EMBEDDINGS=false
EMBEDDINGS_PROVIDER=openai
GENERATION_CHUNK_STORAGE=redis
GENERATION_CHUNK_TTL=3600

INTEL_DEFAULT_PROVIDER=abacus
PYTHON_INTEL_URL=http://127.0.0.1:8001
CREWAI_TRACING_ENABLED=false

# -----------------------------------------------------------------------------
# NEO4J (si se usa sincronización de grafo)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://<CAMBIAR>:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<CAMBIAR>

# -----------------------------------------------------------------------------
# N8N / WEBHOOKS
# -----------------------------------------------------------------------------
N8N_WEBHOOK_URL=<CAMBIAR o dejar vacío>

# -----------------------------------------------------------------------------
# AWS (si se usa S3 para almacenamiento)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=<CAMBIAR o dejar vacío>
AWS_SECRET_ACCESS_KEY=<CAMBIAR o dejar vacío>
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=stratos-prod
AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# BCRYPT
# -----------------------------------------------------------------------------
# En producción usar 12+ para mayor seguridad (default: 10)
BCRYPT_ROUNDS=12

# =============================================================================
# CHECKLIST ANTES DE USAR ESTE ARCHIVO:
#   [ ] Todos los <CAMBIAR> han sido reemplazados
#   [ ] APP_DEBUG=false confirmado
#   [ ] APP_KEY generada (no la de .env.example)
#   [ ] SESSION_SECURE_COOKIE=true (requiere HTTPS)
#   [ ] QUEUE_CONNECTION=redis (no sync)
#   [ ] LOG_LEVEL=warning (no debug)
#   [ ] SENTRY_LARAVEL_DSN configurado
#   [ ] REDIS_PASSWORD coincide con redis.conf
#   [ ] DB_PASSWORD es nueva y fuerte (no la de dev)
# =============================================================================
